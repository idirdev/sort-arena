{
  "name": "sort-arena",
  "version": "1.0.0",
  "description": "Sorting algorithm benchmark and comparison tool",
  "author": "idirdev",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "bench": "tsx src/index.ts --all",
    "compare": "tsx src/index.ts --compare",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "vitest": "^2.0.0"
  }
}
